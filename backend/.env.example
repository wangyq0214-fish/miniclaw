# Mini-OpenClaw Environment Configuration
# Copy this file to .env and fill in your values

# LLM API Configuration
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=qwen3-vl-235b-a22b-thinking

# Embedding Model Configuration
EMBEDDING_API_BASE=http://localhost:4000/v1
EMBEDDING_API_KEY=sk-1234
EMBEDDING_MODEL=dashscope/text-embedding-v3

# Direct Embedding Service (for Neo4j vector search)
EMBEDDING_DIRECT_URL=http://localhost:18869/v1/embeddings
EMBEDDING_DIRECT_MODEL=qwen3-embedding:8b
EMBEDDING_MAX_RETRIES=3

# Tool Calling
ENABLE_TOOL_CALLING=true

# Backend Server
HOST=0.0.0.0
PORT=8002

# Project Root
PROJECT_ROOT=.

# LiteLLM UI
UI_USERNAME=admin
UI_PASSWORD=admin123

# Tavily Web Search (optional)
TAVILY_API_KEY=your-tavily-key-here

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j
NEO4J_FULLTEXT_INDEX=chunkFullTextIndex
NEO4J_VECTOR_INDEX=chunkVectorIndex
